  "info": {
    "title": "Aleph RWA Procurement API",
    "description": "Backend API for permissioned procurement pools, aggregated order tokenization, financing lifecycle, and bridge preparation on Avalanche L1.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "rwa",
      "description": ""
    },
    {
      "name": "auth",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SignupEmailDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "retailer@shop.com"
          },
          "fullName": {
            "type": "string",
            "example": "Retail Partner One"
          },
          "role": {
            "type": "string",
            "enum": ["retailer", "supplier"],
            "example": "retailer"
          },
          "password": {
            "type": "string",
            "example": "StrongPassword!123"
          }
        },
        "required": ["email", "fullName", "role", "password"]
      },
      "WalletResponseDto": {
        "type": "object",
        "properties": {
          "network": {
            "type": "string",
            "example": "fuji"
          },
          "chainId": {
            "type": "number",
            "example": 43113
          },
          "rpcUrl": {
            "type": "string",
            "example": "https://api.avax-test.network/ext/bc/C/rpc"
          },
          "address": {
            "type": "string",
            "example": "0x8ba1f109551bD432803012645Ac136ddd64DBA72"
          },
          "publicKey": {
            "type": "string",
            "example": "0x04f355bdcb7cc0af728ef3cceb9615d90684bb5f0ea7f4f1c0d5f0fd14735f4f83f6d4f2c68f5b26d3f127f4cc13a6b0446dcf8f5e8f138f739b6b4f4d3b6635c4"
          }
        },
        "required": ["network", "chainId", "rpcUrl", "address", "publicKey"]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "usr-kz6r9n2m"
          },
          "email": {
            "type": "string",
            "example": "retailer@shop.com"
          },
          "fullName": {
            "type": "string",
            "example": "Retail Partner One"
          },
          "role": {
            "type": "string",
            "enum": ["retailer", "supplier"],
            "example": "retailer"
          },
          "provider": {
            "type": "string",
            "enum": ["email", "google"],
            "example": "email"
          },
          "wallet": {
            "$ref": "#/components/schemas/WalletResponseDto"
          },
          "createdAt": {
            "type": "string",
            "example": "2026-03-22T12:10:00.000Z"
          }
        },
        "required": [
          "id",
          "email",
          "fullName",
          "role",
          "provider",
          "wallet",
          "createdAt"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c3Ita3o2cjluMm0iLCJlbWFpbCI6InJldGFpbGVyQHNob3AuY29tIiwicm9sZSI6InJldGFpbGVyIiwiaWF0IjoxNzExMTAwMDAwLCJleHAiOjE3MTExMDcyMDB9.signature"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponseDto"
          }
        },
        "required": ["accessToken", "user"]
      },
      "LoginEmailDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "retailer@shop.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPassword!123"
          }
        },
        "required": ["email", "password"]
      },
      "SignupGoogleDto": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "example": "eyJhbGciOiJSUzI1NiIsImtpZCI6Ij...google-id-token...",
            "description": "Google ID token from frontend OAuth flow"
          },
          "role": {
            "type": "string",
            "enum": ["retailer", "supplier"],
            "example": "supplier"
          }
        },
        "required": ["idToken", "role"]
      },
      "LoginGoogleDto": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "example": "eyJhbGciOiJSUzI1NiIsImtpZCI6Ij...google-id-token...",
            "description": "Google ID token from frontend OAuth flow"
          }
        },
        "required": ["idToken"]
      },
      "VerifyMerchantDto": {
        "type": "object",
        "properties": {
          "merchantId": {
            "type": "string",
            "example": "merchant-001"
          },
          "legalName": {
            "type": "string",
            "example": "Retailer ABC Ltd."
          },
          "jurisdiction": {
            "type": "string",
            "example": "MX"
          },
          "metadata": {
            "type": "object",
            "example": {
              "taxId": "ABCD123",
              "businessType": "grocery"
            }
          }
        },
        "required": ["merchantId", "legalName", "jurisdiction"]
      },
      "MerchantProfileResponseDto": {
        "type": "object",
        "properties": {
          "merchantId": {
            "type": "string",
            "example": "merchant-001"
          },
          "legalName": {
            "type": "string",
            "example": "Retailer ABC Ltd."
          },
          "jurisdiction": {
            "type": "string",
            "example": "MX"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "verified", "rejected"],
            "example": "verified"
          },
          "verifiedAt": {
            "type": "string",
            "example": "2026-03-21T19:10:30.000Z"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": ["merchantId", "legalName", "jurisdiction", "status"]
      },
      "CreatePoolDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "North Zone Q2 Procurement Pool"
          },
          "allowedMerchants": {
            "example": ["merchant-001", "merchant-002"],
            "description": "Permissioned merchant IDs allowed to participate in the pool",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["name", "allowedMerchants"]
      },
      "PurchasePoolResponseDto": {
        "type": "object",
        "properties": {
          "poolId": {
            "type": "string",
            "example": "pool-1711032191000-q9s9p2mz"
          },
          "name": {
            "type": "string",
            "example": "North Zone Q2 Procurement Pool"
          },
          "permissioned": {
            "type": "boolean",
            "example": true
          },
          "allowedMerchants": {
            "example": ["merchant-001", "merchant-002"],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "example": "2026-03-21T20:05:11.000Z"
          },
          "chainPoolAddress": {
            "type": "string",
            "example": "pool-44d8ca89d2b19b8a"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "open", "committed", "funded", "settled"],
            "example": "open"
          }
        },
        "required": [
          "poolId",
          "name",
          "permissioned",
          "allowedMerchants",
          "createdAt",
          "status"
        ]
      },
      "CommitOrderDto": {
        "type": "object",
        "properties": {
          "poolId": {
            "type": "string",
            "example": "pool-1711032191000-q9s9p2mz"
          },
          "merchantId": {
            "type": "string",
            "example": "merchant-001"
          },
          "sku": {
            "type": "string",
            "example": "cooking-oil-5l"
          },
          "quantity": {
            "type": "number",
            "example": 120
          },
          "unitPrice": {
            "type": "number",
            "example": 18.75
          },
          "notes": {
            "type": "string",
            "example": "Need delivery before next Friday"
          }
        },
        "required": ["poolId", "merchantId", "sku", "quantity", "unitPrice"]
      },
      "MerchantOrderCommitmentResponseDto": {
        "type": "object",
        "properties": {
          "commitmentId": {
            "type": "string",
            "example": "commitment-1711032287440-v3g2f8qk"
          },
          "poolId": {
            "type": "string",
            "example": "pool-1711032191000-q9s9p2mz"
          },
          "merchantId": {
            "type": "string",
            "example": "merchant-001"
          },
          "sku": {
            "type": "string",
            "example": "cooking-oil-5l"
          },
          "quantity": {
            "type": "number",
            "example": 120
          },
          "unitPrice": {
            "type": "number",
            "example": 18.75
          },
          "encryptedPayload": {
            "type": "string",
            "example": "AQQ4oB6h4NbcY2U..."
          },
          "hash": {
            "type": "string",
            "example": "a5850f2e6c11f99d8b4f91fb8fcb4e74cc4385dc323f928456fca2d2b49d53ab"
          },
          "committedAt": {
            "type": "string",
            "example": "2026-03-21T20:12:00.000Z"
          }
        },
        "required": [
          "commitmentId",
          "poolId",
          "merchantId",
          "sku",
          "quantity",
          "unitPrice",
          "encryptedPayload",
          "hash",
          "committedAt"
        ]
      },
      "AggregateOrderDto": {
        "type": "object",
        "properties": {
          "poolId": {
            "type": "string",
            "example": "pool-1711032191000-q9s9p2mz"
          }
        },
        "required": ["poolId"]
